        <mxCell id="vdm_xconn_tbl" parent="1" style="text;html=1;align=left;verticalAlign=top;overflow=auto;fontSize=9;" value="&lt;table style=&quot;font-size:9px;border-collapse:collapse;width:100%;&quot;&gt;&lt;tr style=&quot;background:#4a6fa5;color:white;&quot;&gt;&lt;th style=&quot;padding:4px;border:1px solid #333;&quot;&gt;Xconnect Group&lt;/th&gt;&lt;th style=&quot;padding:4px;border:1px solid #333;&quot;&gt;Source&lt;/th&gt;&lt;th style=&quot;padding:4px;border:1px solid #333;&quot;&gt;Destination&lt;/th&gt;&lt;th style=&quot;padding:4px;border:1px solid #333;&quot;&gt;PW-ID&lt;/th&gt;&lt;th style=&quot;padding:4px;border:1px solid #333;&quot;&gt;PW-Class&lt;/th&gt;&lt;th style=&quot;padding:4px;border:1px solid #333;&quot;&gt;Service&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#e8f0fe;&quot;&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PTN&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90KKY03 Te0/1/0/2&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90ORT03 (10.134.34.128)&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;35713006&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;EOMPLS-ETH&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PTN inter-site&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;3RD90KKY01&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90KKY03 BE16.2185&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;BE40.2185 (local)&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;-&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;Local xconn&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;Corporate IPsec&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#e8f0fe;&quot;&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;EOMPLS_xconnect&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90KKY03 Gi7001/0/0/1&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90ORT01 (192.168.1.1)&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;35713001&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;EOMPLS-ETH&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;Inter-AS L2 to ORT&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;EOMPLS_xconnect&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90KKY03 BE40.2187&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90ORT03 (10.134.34.128)&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;35713004&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;EOMPLS-VLAN&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;Corporate KKY→ORT&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#e8f0fe;&quot;&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;EOMPLS_xconnect&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90KKY03 BE40.2906&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;PE90ORT03 (10.134.34.128)&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;35713002&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;EOMPLS-VLAN&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #ccc;&quot;&gt;Intermedia KKY→ORT&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="180" width="1080" x="10" y="1215" as="geometry" />
        </mxCell>
        <mxCell id="vdm_note" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#ffffcc;strokeColor=#d6b656;rounded=1;" value="&lt;b&gt;Key Observations:&lt;/b&gt;&lt;br&gt;• PE90KKY03/04 carry ALL 24 VRFs + 73 bridge domains (heaviest devices)&lt;br&gt;• PE90ORT03/04 carry 22-23 VRFs but minimal L2 (mostly L3 VPN)&lt;br&gt;• 4G-IPSEC missing on ORT04 (only KKY03, KKY04, ORT03)&lt;br&gt;• DISNAT_KKY only on KKY03/04 (KKY-specific distributed NAT)&lt;br&gt;• PEX01/02 handle Internet/NAT/Corporate — separate from mobile core VRFs&lt;br&gt;• PE90KKY01/02 (legacy 7609-S) only have CPNMGMT VRF in IOS config, rest via eBGP VPNv4 Option B from KKY03/04&lt;br&gt;• CPNMGMT is the only VRF spanning ALL 7 PE devices" vertex="1">
          <mxGeometry height="120" width="700" y="1410" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
