        <mxCell id="bd_be5042" parent="1" style="rounded=1;html=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;align=center;" value="BE5042 (40G L2 trunk)&lt;br&gt;KKY03 ↔ KKY04&lt;br&gt;&lt;font style=&#39;font-size:8px;font-weight:normal&#39;&gt;Carries .91 .92 .99 .101 .130 .135 .136 .137 etc.&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="320" x="350" y="350" as="geometry" />
        </mxCell>
        <mxCell id="bd_be222" parent="1" style="rounded=1;html=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;align=center;" value="BE222 (20G L2 trunk)&lt;br&gt;KKY03 ↔ KKY01 (gecici)&lt;br&gt;&lt;font style=&#39;font-size:8px;font-weight:normal&#39;&gt;Carries .101 .110 .130 .137 .140 etc.&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="330" x="350" y="430" as="geometry" />
        </mxCell>
        <mxCell id="bd_legend" parent="1" style="rounded=1;html=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#333333;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;b&gt;Legend:&lt;/b&gt;&lt;br&gt;&lt;font color=&#39;#82b366&#39;&gt;██&lt;/font&gt; Bridge-Domain with BVI (L2 switch + L3 gateway → VRF → MPLS L3VPN)&lt;br&gt;&lt;font color=&#39;#d6b656&#39;&gt;██&lt;/font&gt; Bridge-Domain without BVI (pure L2 switching, no L3)&lt;br&gt;&lt;font color=&#39;#b85450&#39;&gt;██&lt;/font&gt; L2 trunk between local PE routers (same site)&lt;br&gt;&lt;br&gt;&lt;b&gt;Key:&lt;/b&gt; All bridge-domains are LOCAL to the site.&lt;br&gt;No L2 traffic crosses MPLS core. Only L3 (VRF/L3VPN) exits via BVI." vertex="1">
          <mxGeometry height="130" width="450" x="-50" y="950" as="geometry" />
        </mxCell>
        <mxCell id="2YhEZUKWI0J3xYkAcsJK-1" parent="1" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=middle;rounded=0;fontColor=light-dark(#ff0000, #ededed);labelBackgroundColor=default;" value="&lt;p style=&quot;white-space-collapse: preserve; margin-top: 0px; margin-bottom: 0.2em; font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px;&quot;&gt;BD 99 + BVI99 için tüm config parçaları:&lt;/p&gt;&lt;p style=&quot;white-space-collapse: preserve; margin-top: 0.1em; margin-bottom: 0.2em; font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px;&quot;&gt;&lt;strong&gt;1. BVI Interface (L3 Gateway):&lt;/strong&gt;&lt;/p&gt;&lt;div class=&quot;codeBlockWrapper_-a7MRw&quot; style=&quot;position: relative; margin: 8px 0px; font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px;&quot;&gt;&lt;button class=&quot;copyButton_CEmTFw copyButton_-a7MRw&quot; title=&quot;Copy code&quot; aria-label=&quot;Copy code to clipboard&quot; style=&quot;font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px; background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box; border-color: rgb(42, 43, 44); border-image: none 100% / 1 / 0 stretch; cursor: pointer; opacity: 0; display: flex; justify-content: center; align-items: center; padding: 4px; transition: opacity 0.15s, background 0.15s; position: absolute; top: 4px; right: 4px;&quot;&gt;&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; viewBox=&quot;0 0 20 20&quot; fill=&quot;currentColor&quot; aria-hidden=&quot;true&quot; data-slot=&quot;icon&quot; class=&quot;copyIcon_CEmTFw&quot;&gt;&lt;path fill-rule=&quot;evenodd&quot; d=&quot;M15.988 3.012A2.25 2.25 0 0 1 18 5.25v6.5A2.25 2.25 0 0 1 15.75 14H13.5v-3.379a3 3 0 0 0-.879-2.121l-3.12-3.121a3 3 0 0 0-1.402-.791 2.252 2.252 0 0 1 1.913-1.576A2.25 2.25 0 0 1 12.25 1h1.5a2.25 2.25 0 0 1 2.238 2.012ZM11.5 3.25a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 .75.75v.25h-3v-.25Z&quot; clip-rule=&quot;evenodd&quot;&gt;&lt;/path&gt;&lt;path d=&quot;M3.5 6A1.5 1.5 0 0 0 2 7.5v9A1.5 1.5 0 0 0 3.5 18h7a1.5 1.5 0 0 0 1.5-1.5v-5.879a1.5 1.5 0 0 0-.44-1.06L8.44 6.439A1.5 1.5 0 0 0 7.378 6H3.5Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px;&quot;&gt;&lt;code style=&quot;padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;interface BVI99&lt;br&gt; description USN&lt;br&gt; vrf 4G-S1-CP&lt;br&gt; ipv4 address 192.168.246.2 255.255.255.248&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p style=&quot;white-space-collapse: preserve; margin-top: 0.1em; margin-bottom: 0.2em; font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px;&quot;&gt;&lt;strong&gt;2. Bridge-Domain (L2 Switching):&lt;/strong&gt;&lt;/p&gt;&lt;div class=&quot;codeBlockWrapper_-a7MRw&quot; style=&quot;position: relative; margin: 8px 0px; font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px;&quot;&gt;&lt;button class=&quot;copyButton_CEmTFw copyButton_-a7MRw&quot; title=&quot;Copy code&quot; aria-label=&quot;Copy code to clipboard&quot; style=&quot;font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px; background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box; border-color: rgb(42, 43, 44); border-image: none 100% / 1 / 0 stretch; cursor: pointer; opacity: 0; display: flex; justify-content: center; align-items: center; padding: 4px; transition: opacity 0.15s, background 0.15s; position: absolute; top: 4px; right: 4px;&quot;&gt;&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; viewBox=&quot;0 0 20 20&quot; fill=&quot;currentColor&quot; aria-hidden=&quot;true&quot; data-slot=&quot;icon&quot; class=&quot;copyIcon_CEmTFw&quot;&gt;&lt;path fill-rule=&quot;evenodd&quot; d=&quot;M15.988 3.012A2.25 2.25 0 0 1 18 5.25v6.5A2.25 2.25 0 0 1 15.75 14H13.5v-3.379a3 3 0 0 0-.879-2.121l-3.12-3.121a3 3 0 0 0-1.402-.791 2.252 2.252 0 0 1 1.913-1.576A2.25 2.25 0 0 1 12.25 1h1.5a2.25 2.25 0 0 1 2.238 2.012ZM11.5 3.25a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 .75.75v.25h-3v-.25Z&quot; clip-rule=&quot;evenodd&quot;&gt;&lt;/path&gt;&lt;path d=&quot;M3.5 6A1.5 1.5 0 0 0 2 7.5v9A1.5 1.5 0 0 0 3.5 18h7a1.5 1.5 0 0 0 1.5-1.5v-5.879a1.5 1.5 0 0 0-.44-1.06L8.44 6.439A1.5 1.5 0 0 0 7.378 6H3.5Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px;&quot;&gt;&lt;code style=&quot;padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;l2vpn bridge group CPN bridge-domain 99&lt;br&gt; interface TenGigE0/2/0/3                          ← fiziksel port (cihaza gelen kablo)&lt;br&gt;  storm-control multicast pps 1000&lt;br&gt;  storm-control broadcast pps 1000&lt;br&gt; interface Bundle-Ether5042.99                      ← KKY04&#39;e L2 trunk (40G)&lt;br&gt;  storm-control multicast pps 1000&lt;br&gt;  storm-control broadcast pps 1000&lt;br&gt; routed interface BVI99                             ← L3 gateway bağlantısı&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p style=&quot;white-space-collapse: preserve; margin-top: 0.1em; margin-bottom: 0.2em; font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px;&quot;&gt;&lt;strong&gt;3. HSRP (Gateway Redundancy - KKY03 ↔ KKY04):&lt;/strong&gt;&lt;/p&gt;&lt;div class=&quot;codeBlockWrapper_-a7MRw&quot; style=&quot;position: relative; margin: 8px 0px; font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px;&quot;&gt;&lt;button class=&quot;copyButton_CEmTFw copyButton_-a7MRw&quot; title=&quot;Copy code&quot; aria-label=&quot;Copy code to clipboard&quot; style=&quot;font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif; font-size: 13px; background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box; border-color: rgb(42, 43, 44); border-image: none 100% / 1 / 0 stretch; cursor: pointer; opacity: 0; display: flex; justify-content: center; align-items: center; padding: 4px; transition: opacity 0.15s, background 0.15s; position: absolute; top: 4px; right: 4px;&quot;&gt;&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; viewBox=&quot;0 0 20 20&quot; fill=&quot;currentColor&quot; aria-hidden=&quot;true&quot; data-slot=&quot;icon&quot; class=&quot;copyIcon_CEmTFw&quot;&gt;&lt;path fill-rule=&quot;evenodd&quot; d=&quot;M15.988 3.012A2.25 2.25 0 0 1 18 5.25v6.5A2.25 2.25 0 0 1 15.75 14H13.5v-3.379a3 3 0 0 0-.879-2.121l-3.12-3.121a3 3 0 0 0-1.402-.791 2.252 2.252 0 0 1 1.913-1.576A2.25 2.25 0 0 1 12.25 1h1.5a2.25 2.25 0 0 1 2.238 2.012ZM11.5 3.25a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 .75.75v.25h-3v-.25Z&quot; clip-rule=&quot;evenodd&quot;&gt;&lt;/path&gt;&lt;path d=&quot;M3.5 6A1.5 1.5 0 0 0 2 7.5v9A1.5 1.5 0 0 0 3.5 18h7a1.5 1.5 0 0 0 1.5-1.5v-5.879a1.5 1.5 0 0 0-.44-1.06L8.44 6.439A1.5 1.5 0 0 0 7.378 6H3.5Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px;&quot;&gt;&lt;code style=&quot;padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;router hsrp interface BVI99&lt;br&gt; hsrp delay minimum 180 reload 360&lt;br&gt; address-family ipv4 hsrp 99&lt;br&gt;  timers msec 1000 msec 3000&lt;br&gt;  preempt delay 180&lt;br&gt;  priority 120                                      ← KKY03 primary (120 &amp;gt; default 100)&lt;br&gt;  address 192.168.246.1                             ← virtual IP (cihazlar bunu GW olarak kullanır)&lt;br&gt;  track object HSRP-CORE-TRACK 100&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="1050" x="1240" y="230" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
