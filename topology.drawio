        <mxCell id="l2_bd_table" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;align=left;verticalAlign=top;fontSize=9;spacingLeft=8;spacingTop=5;" value="&lt;b&gt;Bridge Domain Summary by VRF (KKY03)&lt;/b&gt;&lt;br&gt;&lt;br&gt;VF (General): 8 BDs (110,130,135,136,137,270,272,850,851,999)&lt;br&gt;SIGTRAN: 7 BDs (200,304,402,404,407,432,603,1600,1601,1608,1609)&lt;br&gt;USERPLANE: 9 BDs (300,305,306,408,433,1300,1603-1606,1611)&lt;br&gt;4G-S1-UP: 2 BDs (310,311)&lt;br&gt;4G-S1-CP: 3 BDs (99,410,411)&lt;br&gt;4G-IPSEC: 5 BDs (352,353,802,1802,2211)&lt;br&gt;3GPS_DATA: 5 BDs (307,308,409,420,1400,2000)&lt;br&gt;OandM: 4 BDs (160,566,1607,1610)&lt;br&gt;2G3GUP: 2 BDs (431,3002)&lt;br&gt;CIMS: 1 BD (434)&lt;br&gt;No VRF: ~5 BDs (91,92,101,140,250)&lt;br&gt;&lt;br&gt;&lt;b&gt;Total: 73 BDs on KKY03, ~55 on KKY04&lt;/b&gt;&lt;br&gt;All BDs have: storm-control 1000pps, MAC aging 1800s, BVI (IRB), MST CPN" vertex="1">
          <mxGeometry height="280" width="380" x="700" y="260" as="geometry" />
        </mxCell>
        <mxCell id="l2_xc_table" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;align=left;verticalAlign=top;fontSize=9;spacingLeft=8;spacingTop=5;" value="&lt;b&gt;EOMPLS Xconnect Circuits (P2P Pseudowires)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=red&gt;PTN Transport:&lt;/font&gt;&lt;br&gt;  KKY03 Te0/1/0/2 ↔ ORT03 Te0/1/1/2 (PW 35713006)&lt;br&gt;  KKY04 Te0/1/0/2 ↔ ORT04 Te0/1/1/2 (PW 35713007)&lt;br&gt;&lt;br&gt;&lt;font color=green&gt;CORPORATE:&lt;/font&gt;&lt;br&gt;  KKY03 BE40.2187 ↔ ORT03 BE16.2187 (PW 35713004)&lt;br&gt;  KKY04 BE40.2188 ↔ ORT04 BE16.2188 (PW 35713005)&lt;br&gt;&lt;br&gt;&lt;font color=orange&gt;INTERMEDIA:&lt;/font&gt;&lt;br&gt;  KKY03 BE40.2906 ↔ ORT03 BE16.2906 (PW 35713005)&lt;br&gt;  KKY04 BE40.2907 ↔ ORT04 BE16.2907 (PW 35713003)&lt;br&gt;&lt;br&gt;&lt;font color=#CC0066&gt;Legacy:&lt;/font&gt;&lt;br&gt;  KKY03 Gi7001/0/0/1 ↔ ORT01 (PW 35713001)&lt;br&gt;&lt;br&gt;&lt;b&gt;Local Xconnects (3RD IPsec GW):&lt;/b&gt;&lt;br&gt;  3RD01: BE16.2185↔BE40.2185, BE16.2946↔BE40.2946&lt;br&gt;  3RD02: BE16.2186↔BE40.2186, BE16.2947↔BE40.2947" vertex="1">
          <mxGeometry height="320" width="380" x="700" y="560" as="geometry" />
        </mxCell>
        <mxCell id="l2_legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;align=left;verticalAlign=top;fontSize=9;spacingLeft=8;spacingTop=5;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=blue&gt;━━━ L2 Trunk / BE5042 (Bridge Domains)&lt;/font&gt;&lt;br&gt;&lt;font color=#d6b656&gt;━━━ Legacy L2 Trunk (VLAN)&lt;/font&gt;&lt;br&gt;&lt;font color=#9673a6&gt;━━━ BE222 L2 BD uplink&lt;/font&gt;&lt;br&gt;&lt;font color=#FF0000&gt;- - - EOMPLS PTN Pseudowire (inter-site)&lt;/font&gt;&lt;br&gt;&lt;font color=#009900&gt;- - - EOMPLS CORPORATE Pseudowire&lt;/font&gt;&lt;br&gt;&lt;font color=#FF6600&gt;- - - EOMPLS INTERMEDIA Pseudowire&lt;/font&gt;&lt;br&gt;&lt;font color=#CC0066&gt;- - - EOMPLS Legacy Pseudowire&lt;/font&gt;&lt;br&gt;&lt;font color=#82b366&gt;━━━ 3RD GW Local Xconnect (BE40)&lt;/font&gt;" vertex="1">
          <mxGeometry height="200" width="300" x="-50" y="690" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
